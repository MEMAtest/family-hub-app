// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User authentication table
model User {
  id           String   @id @default(cuid())
  neonAuthId   String?  @unique @map("neon_auth_id")
  email        String   @unique
  password     String?
  displayName  String?  @map("display_name")
  avatarUrl    String?  @map("avatar_url")
  authProvider String   @default("email") @map("auth_provider")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  familyMembers FamilyMember[]
  ownedFamilies Family[]       @relation("FamilyOwner")
  sentHouseholdInvites HouseholdInvite[] @relation("HouseholdInviteCreator")

  @@map("users")
}

// Families table
model Family {
  id         String   @id @default(cuid())
  familyName String   @map("family_name")
  familyCode String   @unique @map("family_code")
  ownerId    String?  @map("owner_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  owner                 User?          @relation("FamilyOwner", fields: [ownerId], references: [id])
  members               FamilyMember[]
  calendarEvents        CalendarEvent[]
  budgetIncome          BudgetIncome[]
  budgetExpenses        BudgetExpense[]
  budgetCategories      BudgetCategory[]
  savingsGoals          SavingsGoal[]
  budgetAlerts          BudgetAlert[]
  monthlyBudgetSummaries MonthlyBudgetSummary[]
  mealPlans             MealPlan[]
  shoppingLists         ShoppingList[]
  familyGoals           FamilyGoal[]
  achievements          Achievement[]
  milestones            FamilyMilestone[]
  fitnessImages         FitnessImage[]
  contractors           Contractor[]
  contractorAppointments ContractorAppointment[]
  notifications         Notification[]
  pushSubscriptions     PushSubscription[]
  brainProjects         BrainProject[]
  calendarEmailIntakes  CalendarEmailIntake[]
  googleCalendarConnections GoogleCalendarConnection[]
  householdInvites      HouseholdInvite[]
  budgetAccounts        BudgetAccount[]
  statementImports      StatementImport[]
  budgetTransactions    BudgetTransaction[]

  @@map("families")
}

// Family members table
model FamilyMember {
  id           String   @id @default(cuid())
  familyId     String   @map("family_id")
  userId       String?  @map("user_id")
  name         String
  role         String
  ageGroup     String   @map("age_group")
  dateOfBirth  DateTime? @map("date_of_birth")
  avatarUrl    String?  @map("avatar_url")
  color        String   // Hex color code
  icon         String   // Emoji icon
  fitnessGoals Json?    @map("fitness_goals")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  family           Family             @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user             User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  calendarEvents   CalendarEvent[]
  budgetIncome     BudgetIncome[]
  budgetExpenses   BudgetExpense[]
  shoppingItems    ShoppingItem[]
  achievements     Achievement[]
  fitnessTracking  FitnessTracking[]
  deviceSyncs      DeviceSync[]
  fitnessImagesUploaded FitnessImage[]
  receivedHouseholdInvites HouseholdInvite[] @relation("HouseholdInviteTarget")
  fragrances        Fragrance[]
  fragranceDrafts   FragranceDraft[]
  fragranceWearLogs FragranceWearLog[]
  fragranceCandidates FragranceCandidate[]
  cycleProfile      CycleProfile?
  cyclePeriods      CyclePeriod[]
  cycleDailyLogs    CycleDailyLog[]
  cycleReminders    CycleReminder[]
  personalGoogleCalendarConnection PersonalGoogleCalendarConnection?

  @@index([familyId, userId])
  @@map("family_members")
}

model FamilyMilestone {
  id           String   @id @default(cuid())
  familyId     String   @map("family_id")
  title        String
  description  String?
  date         DateTime
  type         String
  participants Json?    // Array of member IDs
  photos       Json?    // Array of URLs
  tags         Json?    // Array of strings
  isRecurring  Boolean  @default(false) @map("is_recurring")
  reminderDays Json?    @map("reminder_days")
  isPrivate    Boolean  @default(false) @map("is_private")
  createdBy    String?  @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@map("family_milestones")
}

// Calendar events table
model CalendarEvent {
  id               String   @id @default(cuid())
  familyId         String   @map("family_id")
  personId         String   @map("person_id")
  title            String
  description      String?
  eventDate        DateTime @map("event_date")
  eventTime        DateTime @map("event_time")
  durationMinutes  Int      @default(60) @map("duration_minutes")
  location         String?
  cost             Float    @default(0.00)
  eventType        String   @map("event_type")
  recurringPattern String   @default("none") @map("recurring_pattern")
  isRecurring      Boolean  @default(false) @map("is_recurring")
  notes            String?
  source           String?  @map("source")
  sourceId         String?  @map("source_id")
  googleCalendarId String?  @map("google_calendar_id")
  googleEventId    String?  @map("google_event_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  family Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  person FamilyMember @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([familyId, source, sourceId])
  @@index([familyId, googleCalendarId, googleEventId])
  @@map("calendar_events")
}

model CalendarEmailIntake {
  id             String   @id @default(cuid())
  familyId       String   @map("family_id")
  messageId      String?  @map("message_id")
  recipient      String?
  sender         String?
  subject        String?
  text           String?
  html           String?
  normalizedText String?  @map("normalized_text")
  parsedDrafts   Json     @map("parsed_drafts")
  createdEventIds Json?   @map("created_event_ids")
  status         String   @default("review_required")
  autoCreated    Int      @default(0) @map("auto_created")
  needsReview    Int      @default(0) @map("needs_review")
  duplicateCount Int      @default(0) @map("duplicate_count")
  conflictCount  Int      @default(0) @map("conflict_count")
  metadata       Json?
  receivedAt     DateTime @default(now()) @map("received_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId, receivedAt])
  @@index([familyId, status])
  @@map("calendar_email_intakes")
}

model GoogleCalendarConnection {
  id                String   @id @default(cuid())
  familyId          String   @map("family_id")
  googleUserEmail   String?  @map("google_user_email")
  accessToken       String   @map("access_token")
  refreshToken      String?  @map("refresh_token")
  tokenType         String?  @map("token_type")
  scope             String?
  expiryDate        DateTime? @map("expiry_date")
  selectedCalendarId String? @map("selected_calendar_id")
  selectedCalendarName String? @map("selected_calendar_name")
  syncDirection     String   @default("export") @map("sync_direction")
  enabled           Boolean  @default(true)
  lastExportAt      DateTime? @map("last_export_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([familyId])
  @@index([familyId, enabled])
  @@map("google_calendar_connections")
}

// A one-use household invitation links a signed-in adult to an existing adult profile.
model HouseholdInvite {
  id             String    @id @default(cuid())
  familyId       String    @map("family_id")
  targetMemberId String    @map("target_member_id")
  createdById    String    @map("created_by_id")
  codeHash       String    @unique @map("code_hash")
  expiresAt      DateTime  @map("expires_at")
  usedAt         DateTime? @map("used_at")
  redeemedById   String?   @map("redeemed_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")

  family       Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  targetMember FamilyMember @relation("HouseholdInviteTarget", fields: [targetMemberId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("HouseholdInviteCreator", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([familyId, targetMemberId])
  @@index([expiresAt])
  @@map("household_invites")
}

// Imported statement rows are actuals. Planned income and expenses remain separate commitments.
model BudgetAccount {
  id                 String    @id @default(cuid())
  familyId           String    @map("family_id")
  name               String
  institution        String?
  accountType        String    @default("current") @map("account_type")
  lastFour           String?   @map("last_four")
  currency           String    @default("GBP")
  openingBalance     Float?    @map("opening_balance")
  openingBalanceDate DateTime? @map("opening_balance_date")
  active             Boolean   @default(true)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  family       Family              @relation(fields: [familyId], references: [id], onDelete: Cascade)
  imports      StatementImport[]
  transactions BudgetTransaction[]

  @@index([familyId, active])
  @@map("budget_accounts")
}

model StatementImport {
  id             String    @id @default(cuid())
  familyId       String    @map("family_id")
  accountId      String    @map("account_id")
  fileName       String    @map("file_name")
  sourceType     String    @map("source_type")
  contentHash    String    @map("content_hash")
  statementStart DateTime? @map("statement_start")
  statementEnd   DateTime? @map("statement_end")
  openingBalance Float?    @map("opening_balance")
  closingBalance Float?    @map("closing_balance")
  parsedRows     Int       @default(0) @map("parsed_rows")
  importedRows   Int       @default(0) @map("imported_rows")
  duplicateRows  Int       @default(0) @map("duplicate_rows")
  rejectedRows   Json?     @map("rejected_rows")
  importedById   String    @map("imported_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")

  family       Family              @relation(fields: [familyId], references: [id], onDelete: Cascade)
  account      BudgetAccount       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  transactions BudgetTransaction[]

  @@unique([accountId, contentHash])
  @@index([familyId, createdAt])
  @@map("statement_imports")
}

model BudgetTransaction {
  id                String    @id @default(cuid())
  familyId          String    @map("family_id")
  accountId         String    @map("account_id")
  statementImportId String?   @map("statement_import_id")
  transactionDate   DateTime  @map("transaction_date")
  description       String
  amount            Float
  direction         String
  balance           Float?
  category          String?
  transactionType   String    @default("normal") @map("transaction_type")
  transferGroupId   String?   @map("transfer_group_id")
  fingerprint       String
  source            String    @default("statement")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  family          Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
  account         BudgetAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  statementImport StatementImport? @relation(fields: [statementImportId], references: [id], onDelete: SetNull)

  @@unique([accountId, fingerprint])
  @@index([familyId, transactionDate])
  @@index([transferGroupId])
  @@map("budget_transactions")
}

// Budget income table
model BudgetIncome {
  id                   String    @id @default(cuid())
  familyId             String    @map("family_id")
  personId             String?   @map("person_id")
  incomeName           String    @map("income_name")
  amount               Float
  category             String
  isRecurring          Boolean   @default(true) @map("is_recurring")
  recurringFrequency   String?   @map("recurring_frequency") // 'weekly', 'monthly', 'yearly'
  recurringStartDate   DateTime? @map("recurring_start_date")
  recurringEndDate     DateTime? @map("recurring_end_date") // null = indefinite
  paymentDate          DateTime? @map("payment_date")
  createdAt            DateTime  @default(now()) @map("created_at")

  // Relations
  family Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  person FamilyMember? @relation(fields: [personId], references: [id])

  @@map("budget_income")
}

// Budget expenses table
model BudgetExpense {
  id                   String    @id @default(cuid())
  familyId             String    @map("family_id")
  personId             String?   @map("person_id")
  expenseName          String    @map("expense_name")
  amount               Float
  category             String
  budgetLimit          Float?    @map("budget_limit")
  isRecurring          Boolean   @default(true) @map("is_recurring")
  recurringFrequency   String?   @map("recurring_frequency") // 'weekly', 'monthly', 'yearly'
  recurringStartDate   DateTime? @map("recurring_start_date")
  recurringEndDate     DateTime? @map("recurring_end_date") // null = indefinite
  paymentDate          DateTime? @map("payment_date")
  isReceiptScan        Boolean   @default(false) @map("is_receipt_scan") // Track if from receipt scanner
  receiptScanDate      DateTime? @map("receipt_scan_date") // When the receipt was scanned
  createdAt            DateTime  @default(now()) @map("created_at")

  // Relations
  family Family        @relation(fields: [familyId], references: [id], onDelete: Cascade)
  person FamilyMember? @relation(fields: [personId], references: [id])

  @@map("budget_expenses")
}

// Budget categories table
model BudgetCategory {
  id               String   @id @default(cuid())
  familyId         String   @map("family_id")
  categoryName     String   @map("category_name")
  categoryType     String   @map("category_type") // income, expense
  budgetLimit      Float?   @map("budget_limit")
  colorCode        String?  @map("color_code")
  iconName         String?  @map("icon_name")
  isActive         Boolean  @default(true) @map("is_active")
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([familyId, categoryName, categoryType])
  @@map("budget_categories")
}

// Savings goals table
model SavingsGoal {
  id                String    @id @default(cuid())
  familyId          String    @map("family_id")
  goalName          String    @map("goal_name")
  goalDescription   String?   @map("goal_description")
  targetAmount      Float     @map("target_amount")
  currentAmount     Float     @default(0.00) @map("current_amount")
  targetDate        DateTime? @map("target_date")
  priority          String    @default("medium") // high, medium, low
  category          String    @default("general")
  isActive          Boolean   @default(true) @map("is_active")
  autoContribution  Float?    @map("auto_contribution")
  contributionFreq  String?   @map("contribution_frequency") // weekly, monthly, yearly
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relations
  family        Family              @relation(fields: [familyId], references: [id], onDelete: Cascade)
  contributions SavingsContribution[]

  @@map("savings_goals")
}

// Savings contributions table
model SavingsContribution {
  id              String   @id @default(cuid())
  savingsGoalId   String   @map("savings_goal_id")
  contributionAmount Float    @map("contribution_amount")
  contributionDate   DateTime @map("contribution_date")
  contributionType   String   @default("manual") // manual, automatic
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  savingsGoal SavingsGoal @relation(fields: [savingsGoalId], references: [id], onDelete: Cascade)

  @@map("savings_contributions")
}

// Budget alerts table
model BudgetAlert {
  id                String   @id @default(cuid())
  familyId          String   @map("family_id")
  alertType         String   @map("alert_type") // overspend, goal_progress, recurring_reminder
  alertTitle        String   @map("alert_title")
  alertMessage      String   @map("alert_message")
  severity          String   @default("medium") // low, medium, high, critical
  isActive          Boolean  @default(true) @map("is_active")
  triggerCondition  Json     @map("trigger_condition") // Flexible condition storage
  lastTriggered     DateTime? @map("last_triggered")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@map("budget_alerts")
}

// Monthly budget summary table
model MonthlyBudgetSummary {
  id               String   @id @default(cuid())
  familyId         String   @map("family_id")
  summaryMonth     Int      @map("summary_month") // 1-12
  summaryYear      Int      @map("summary_year")
  totalIncome      Float    @map("total_income")
  totalExpenses    Float    @map("total_expenses")
  netIncome        Float    @map("net_income")
  savingsRate      Float    @map("savings_rate") // Percentage
  categoryBreakdown Json    @map("category_breakdown") // Detailed category spending
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@unique([familyId, summaryMonth, summaryYear])
  @@map("monthly_budget_summaries")
}

// Meal plans table
model MealPlan {
  id                 String    @id @default(cuid())
  familyId           String    @map("family_id")
  mealDate           DateTime  @map("meal_date")
  mealName           String    @map("meal_name")
  proteinSource      String?   @map("protein_source")
  carbohydrateSource String?   @map("carbohydrate_source")
  vegetableSource    String?   @map("vegetable_source")
  estimatedCalories  Int?      @map("estimated_calories")
  mealNotes          String?   @map("meal_notes")
  isEaten            Boolean   @default(false) @map("is_eaten")
  eatenAt            DateTime? @map("eaten_at")
  createdAt          DateTime  @default(now()) @map("created_at")

  // Relations
  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@map("meal_plans")
}

// Shopping lists table
model ShoppingList {
  id          String   @id @default(cuid())
  familyId    String   @map("family_id")
  listName    String   @map("list_name")
  category    String   @default("General")
  storeChain  String?  @map("store_chain") // Tesco, Morrisons, ASDA, Sainsbury's, Lidl, Aldi, Waitrose, Co-op, Iceland, Custom
  customStore String?  @map("custom_store") // Only used when storeChain is "Custom"
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  family Family         @relation(fields: [familyId], references: [id], onDelete: Cascade)
  items  ShoppingItem[]

  @@map("shopping_lists")
}

// Shopping items table
model ShoppingItem {
  id             String    @id @default(cuid())
  listId         String    @map("list_id")
  itemName       String    @map("item_name")
  estimatedPrice Float     @default(0.00) @map("estimated_price")
  category       String    @default("General")
  frequency      String?
  personId       String?   @map("person_id")
  isCompleted    Boolean   @default(false) @map("is_completed")
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  // Relations
  list   ShoppingList  @relation(fields: [listId], references: [id], onDelete: Cascade)
  person FamilyMember? @relation(fields: [personId], references: [id])

  @@map("shopping_items")
}

// Family goals table
model FamilyGoal {
  id              String   @id @default(cuid())
  familyId        String   @map("family_id")
  goalTitle       String   @map("goal_title")
  goalDescription String?  @map("goal_description")
  goalType        String   @map("goal_type") // family, individual
  targetValue     String   @map("target_value")
  currentProgress Int      @default(0) @map("current_progress") // Percentage 0-100
  deadline        DateTime?
  participants    Json     // Array of member IDs
  milestones      Json     // Array of milestone objects
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@map("family_goals")
}

// Achievements table
model Achievement {
  id                     String   @id @default(cuid())
  familyId               String   @map("family_id")
  personId               String   @map("person_id")
  achievementTitle       String   @map("achievement_title")
  achievementDescription String?  @map("achievement_description")
  category               String
  badgeEmoji             String?  @map("badge_emoji")
  pointsAwarded          Int      @default(0) @map("points_awarded")
  achievedDate           DateTime @default(now()) @map("achieved_date")
  createdAt              DateTime @default(now()) @map("created_at")

  // Relations
  family Family       @relation(fields: [familyId], references: [id], onDelete: Cascade)
  person FamilyMember @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@map("achievements")
}

// Fitness tracking table
model FitnessTracking {
  id              String   @id @default(cuid())
  personId        String   @map("person_id")
  activityType    String   @map("activity_type")  // gym, run, swim, cycle, walk, sports, yoga, cardio
  durationMinutes Int      @map("duration_minutes")
  intensityLevel  String   @map("intensity_level") // low, moderate, high
  activityDate    DateTime @default(now()) @map("activity_date")
  notes           String?

  // Extended fields for gym workouts
  calories        Int?
  exercises       Json?                           // Array of ExerciseSet objects
  workoutName     String?  @map("workout_name")   // e.g., "Upper Body", "Leg Day"
  heartRateAvg    Int?     @map("heart_rate_avg")
  heartRateMax    Int?     @map("heart_rate_max")
  source          String   @default("manual")     // manual, garmin, ultrahuman
  externalId      String?  @map("external_id")    // ID from device sync
  imageUrls       Json?    @map("image_urls")     // Array of image URLs (screenshots/photos)

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  person FamilyMember @relation(fields: [personId], references: [id], onDelete: Cascade)
  images FitnessImage[]

  @@map("fitness_tracking")
}

// Fitness images (uploaded screenshots/photos for workouts)
model FitnessImage {
  id               String   @id @default(cuid())
  familyId          String   @map("family_id")
  fitnessTrackingId String?  @map("fitness_tracking_id")
  uploadedById      String?  @map("uploaded_by_id")
  mimeType          String   @map("mime_type")
  sizeBytes         Int      @map("size_bytes")
  data              Bytes
  createdAt         DateTime @default(now()) @map("created_at")

  family     Family           @relation(fields: [familyId], references: [id], onDelete: Cascade)
  activity   FitnessTracking? @relation(fields: [fitnessTrackingId], references: [id], onDelete: Cascade)
  uploadedBy FamilyMember?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([familyId])
  @@index([fitnessTrackingId])
  @@map("fitness_images")
}

// Device sync tracking for Garmin/Ultrahuman integrations (Phase 2)
model DeviceSync {
  id           String    @id @default(cuid())
  personId     String    @map("person_id")
  provider     String                            // garmin, ultrahuman
  accountId    String?   @map("account_id")
  accessToken  String?   @map("access_token")    // encrypted
  refreshToken String?   @map("refresh_token")   // encrypted
  tokenExpiry  DateTime? @map("token_expiry")
  lastSyncAt   DateTime? @map("last_sync_at")
  syncEnabled  Boolean   @default(true) @map("sync_enabled")
  settings     Json?                             // Provider-specific settings
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  person FamilyMember @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([personId, provider])
  @@map("device_syncs")
}

// Personal fragrance collection and wear evidence. Every record belongs to one profile.
model Fragrance {
  id             String    @id @default(cuid())
  personId       String    @map("person_id")
  house          String
  name           String
  concentration  String?
  notes          String?
  photoData      Bytes?    @map("photo_data")
  photoMimeType  String?   @map("photo_mime_type")
  photoSizeBytes Int?      @map("photo_size_bytes")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  person      FamilyMember      @relation(fields: [personId], references: [id], onDelete: Cascade)
  wearLogs    FragranceWearLog[]
  benchmarks  FragranceBenchmark[]

  @@unique([personId, house, name, concentration])
  @@index([personId, createdAt])
  @@map("fragrances")
}

model FragranceDraft {
  id             String   @id @default(cuid())
  personId       String   @map("person_id")
  suggestedHouse String?  @map("suggested_house")
  suggestedName  String?  @map("suggested_name")
  suggestedConcentration String? @map("suggested_concentration")
  extractedText  String?  @map("extracted_text")
  photoData      Bytes    @map("photo_data")
  photoMimeType  String   @map("photo_mime_type")
  photoSizeBytes Int      @map("photo_size_bytes")
  confirmedAt    DateTime? @map("confirmed_at")
  createdAt      DateTime @default(now()) @map("created_at")

  person FamilyMember @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId, createdAt])
  @@map("fragrance_drafts")
}

model FragranceWearLog {
  id          String   @id @default(cuid())
  personId    String   @map("person_id")
  fragranceId String   @map("fragrance_id")
  wornAt      DateTime @default(now()) @map("worn_at")
  overallRating Int?
  longevityHours Float? @map("longevity_hours")
  projectionRating Int? @map("projection_rating")
  context     Json?
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  person    FamilyMember @relation(fields: [personId], references: [id], onDelete: Cascade)
  fragrance Fragrance    @relation(fields: [fragranceId], references: [id], onDelete: Cascade)

  @@index([personId, wornAt])
  @@index([fragranceId, wornAt])
  @@map("fragrance_wear_logs")
}

model FragranceBenchmark {
  id               String   @id @default(cuid())
  fragranceId      String   @map("fragrance_id")
  sourceName       String   @map("source_name")
  sourceUrl        String   @map("source_url")
  capturedAt       DateTime @default(now()) @map("captured_at")
  rating           Float?
  longevityRating  Float?  @map("longevity_rating")
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")

  fragrance Fragrance @relation(fields: [fragranceId], references: [id], onDelete: Cascade)

  @@index([fragranceId, capturedAt])
  @@map("fragrance_benchmarks")
}

// Curated, sourced candidates support recommendations without scraping or invented ratings.
model FragranceCandidate {
  id              String   @id @default(cuid())
  personId        String   @map("person_id")
  house           String
  name            String
  concentration   String?
  profile          Json?
  sourceName      String   @map("source_name")
  sourceUrl       String   @map("source_url")
  capturedAt      DateTime @default(now()) @map("captured_at")
  rating          Float?
  longevityRating Float?   @map("longevity_rating")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  person FamilyMember @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([personId, house, name, sourceUrl])
  @@index([personId, capturedAt])
  @@map("fragrance_candidates")
}

// Private cycle records are not family events and are never added to the shared calendar.
model CycleProfile {
  id                    String   @id @default(cuid())
  personId              String   @unique @map("person_id")
  reminderEnabled       Boolean  @default(true) @map("reminder_enabled")
  reminderTime           String? @map("reminder_time")
  personalCalendarEnabled Boolean @default(false) @map("personal_calendar_enabled")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  person FamilyMember @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@map("cycle_profiles")
}

model CyclePeriod {
  id              String    @id @default(cuid())
  personId        String    @map("person_id")
  startDate       DateTime  @map("start_date")
  endDate         DateTime? @map("end_date")
  notes           String?
  calendarEventId String?   @map("calendar_event_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  person FamilyMember @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([personId, startDate])
  @@index([personId, startDate])
  @@map("cycle_periods")
}

model CycleDailyLog {
  id          String   @id @default(cuid())
  personId    String   @map("person_id")
  logDate     DateTime @map("log_date")
  flow        String?
  symptoms    Json?
  mood        String?
  energy      Int?
  sleepHours  Float?   @map("sleep_hours")
  painLevel   Int?     @map("pain_level")
  medication  String?
  tags        Json?
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  person FamilyMember @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([personId, logDate])
  @@index([personId, logDate])
  @@map("cycle_daily_logs")
}

model CycleReminder {
  id              String   @id @default(cuid())
  personId        String   @map("person_id")
  reminderType    String   @map("reminder_type")
  daysBefore      Int      @default(0) @map("days_before")
  timeOfDay       String?  @map("time_of_day")
  enabled         Boolean  @default(true)
  calendarEventId String?  @map("calendar_event_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  person FamilyMember @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([personId, reminderType])
  @@map("cycle_reminders")
}

model PersonalGoogleCalendarConnection {
  id                   String    @id @default(cuid())
  personId             String    @unique @map("person_id")
  googleUserEmail      String?   @map("google_user_email")
  accessToken          String    @map("access_token")
  refreshToken         String?   @map("refresh_token")
  tokenType            String?   @map("token_type")
  scope                String?
  expiryDate           DateTime? @map("expiry_date")
  selectedCalendarId   String?   @map("selected_calendar_id")
  selectedCalendarName String?   @map("selected_calendar_name")
  enabled              Boolean   @default(true)
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  person FamilyMember @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@map("personal_google_calendar_connections")
}

// Contractors (Phase 2)
model Contractor {
  id        String   @id @default(cuid())
  familyId  String   @map("family_id")
  name      String
  company   String?
  phone     String?
  email     String?
  address   String?
  specialty String
  notes     String?
  rating    Int?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  family       Family                 @relation(fields: [familyId], references: [id], onDelete: Cascade)
  appointments ContractorAppointment[]

  @@index([familyId])
  @@index([familyId, specialty])
  @@map("contractors")
}

model ContractorAppointment {
  id              String   @id @default(cuid())
  familyId         String   @map("family_id")
  contractorId     String   @map("contractor_id")
  date            String   // YYYY-MM-DD
  time            String   // HH:MM
  durationMinutes Int      @map("duration_minutes")
  purpose         String
  location        String?
  notes           String?
  cost            Float?
  status          String
  calendarEventId String?  @map("calendar_event_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  family     Family      @relation(fields: [familyId], references: [id], onDelete: Cascade)
  contractor Contractor  @relation(fields: [contractorId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@index([familyId, date])
  @@index([contractorId])
  @@map("contractor_appointments")
}

// In-app notifications persistence (Phase 4)
model Notification {
  id              String   @id @default(cuid())
  familyId         String   @map("family_id")
  type            String
  title           String
  message         String
  icon            String?
  priority        String
  category        String
  timestamp       DateTime @default(now())
  read            Boolean  @default(false)
  actionRequired  Boolean  @default(false) @map("action_required")
  actions         Json?
  relatedEventId  String?  @map("related_event_id")
  relatedPersonId String?  @map("related_person_id")
  expiresAt       DateTime? @map("expires_at")
  snoozedUntil    DateTime? @map("snoozed_until")
  metadata        Json?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId, read])
  @@index([familyId, timestamp])
  @@map("notifications")
}

model PushSubscription {
  id          String   @id @default(cuid())
  familyId    String   @map("family_id")
  endpoint    String   @unique
  p256dh      String
  auth        String
  userAgent   String?  @map("user_agent")
  deviceLabel String?  @map("device_label")
  isActive    Boolean  @default(true) @map("is_active")
  lastSeenAt  DateTime @default(now()) @map("last_seen_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([familyId, isActive])
  @@map("push_subscriptions")
}

// Brain mind-map projects
model BrainProject {
  id          String   @id @default(cuid())
  familyId    String   @map("family_id")
  name        String
  description String?
  color       String   @default("#6366F1") // Hex color
  icon        String   @default("brain")   // Lucide icon name
  status      String   @default("active")  // active, archived, completed
  sortOrder   Int      @default(0) @map("sort_order")
  goalId      String?  @map("goal_id")     // Optional link to FamilyGoal
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  family Family      @relation(fields: [familyId], references: [id], onDelete: Cascade)
  nodes  BrainNode[]
  edges  BrainEdge[]

  @@index([familyId])
  @@index([familyId, status])
  @@map("brain_projects")
}

// Brain mind-map nodes
model BrainNode {
  id             String    @id @default(cuid())
  projectId      String    @map("project_id")
  title          String
  content        String?   // Markdown
  status         String    @default("todo")       // todo, in_progress, done, blocked, idea
  priority       String    @default("medium")      // low, medium, high, urgent
  dueDate        DateTime? @map("due_date")
  nodeType       String    @default("thought") @map("node_type") // thought, task, idea, note, milestone
  positionX      Float     @default(0) @map("position_x")
  positionY      Float     @default(0) @map("position_y")
  tags           Json      @default("[]")
  showOnCalendar Boolean   @default(false) @map("show_on_calendar")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  project     BrainProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceEdges BrainEdge[]  @relation("SourceNode")
  targetEdges BrainEdge[]  @relation("TargetNode")

  @@index([projectId])
  @@index([projectId, status])
  @@index([projectId, dueDate])
  @@map("brain_nodes")
}

// Brain mind-map edges (connections between nodes)
model BrainEdge {
  id           String   @id @default(cuid())
  projectId    String   @map("project_id")
  sourceNodeId String   @map("source_node_id")
  targetNodeId String   @map("target_node_id")
  label        String?
  edgeType     String   @default("default") @map("edge_type") // default, dependency, related, sequence
  animated     Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")

  project    BrainProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceNode BrainNode    @relation("SourceNode", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode BrainNode    @relation("TargetNode", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@unique([sourceNodeId, targetNodeId])
  @@index([projectId])
  @@map("brain_edges")
}
